# Frontend environment for the AI chat panel.
# Copy this file to .env and fill in real values. .env is gitignored.
#
# The chat talks to any OpenAI-compatible /chat/completions endpoint. We keep
# the provider out of the code so the workshop can point at whatever is handy
# (a hosted open model, a local server, etc.). Default is an open model.
#
# NOTE: Vite exposes only vars prefixed with VITE_ to the browser. Any key you
# put here ships to the client, so use a throwaway/limited key for teaching.

VITE_LLM_BASE_URL=https://api.openai.com/v1
VITE_LLM_API_KEY=your-key-here
VITE_LLM_MODEL=gpt-4o-mini
